{
  "name": "zazu",
  "version": "1.10.3",
  "private": true,
  "author": {
    "name": "Samuel Aure",
    "url": "https://www.samuelaure.com"
  },
  "license": "Proprietary",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "scripts": {
    "dev:bot": "npm run dev --workspace=@zazu/bot",
    "dev:dashboard": "npm run dev --workspace=@zazu/dashboard",
    "build": "npm run build --workspaces",
    "start": "npm run start --workspaces",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "npm run test --workspaces",
    "verify": "npm run lint && npm run build",
    "db:push": "npm run prisma:push --workspace=@zazu/db",
    "db:migrate": "npx prisma migrate dev --schema=packages/db/prisma/schema.prisma",
    "db:studio": "npm run prisma:studio --workspace=@zazu/db",
    "release": "standard-version"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "standard-version": "^9.5.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "react": "19.0.0",
    "react-dom": "19.0.0"
  }
}
