datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum OnboardingState {
  AWAITING_NAME
  COMPLETED
}

enum Role {
  USER
  ASSISTANT
}

model User {
  id              String          @id @default(uuid())
  telegramId      BigInt          @unique
  firstName       String?
  lastName        String?
  username        String?
  displayName     String?
  onboardingState OnboardingState @default(AWAITING_NAME)
  messages         Message[]
  features         UserFeature[]
  commentSuggesters CommentSuggester[]
  createdAt        DateTime        @default(now())
}

model Message {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      Role
  content   String
  metadata  Json?
  createdAt DateTime @default(now())
}

model Feature {
  id          String        @id
  name        String
  description String
  users       UserFeature[]
}

model UserFeature {
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  featureId String
  feature   Feature @relation(fields: [featureId], references: [id])
  config    Json?

  @@id([userId, featureId])
}

model CommentSuggester {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  brandName        String
  targetAccounts   String[]
  systemPrompt     String   @db.Text
  scheduleInterval Int      @default(15) // minutes
  activeHours      Json?    // e.g. { "start": "14:00", "end": "20:00" }
  lastCheckAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, brandName])
  @@index([userId])
}
